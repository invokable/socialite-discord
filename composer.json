{
    "name": "revolution/socialite-discord",
    "description": "Socialite for Discord",
    "keywords": [
        "discord",
        "socialite",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.0",
        "ext-json": "*",
        "laravel/socialite": "*"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "laravel/pint": "^1.22",
        "revolution/laravel-boost-copilot-cli": "^2.2"
    },
    "autoload": {
        "psr-4": {
            "Revolution\\Socialite\\Discord\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "authors": [
        {
            "name": "kawax",
            "email": "kawaxbiz@gmail.com"
        }
    ],
    "extra": {
        "laravel": {
            "providers": [
                "Revolution\\Socialite\\Discord\\DiscordServiceProvider"
            ]
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare",
            "@build"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "lint": [
            "@php vendor/bin/pint --ansi"
        ],
        "test": [
            "@clear",
            "@php vendor/bin/phpunit"
        ],
        "boost": "vendor/bin/testbench boost:install --no-interaction --ansi"
    }
}
